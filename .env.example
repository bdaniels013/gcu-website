# Resend API key for the contact form (/api/contact). Required.
# Get it from https://resend.com/api-keys
RESEND_API_KEY=

# Optional. The "from" address for contact-form emails. Must be on a domain
# you've verified in Resend. If unset, Resend's shared onboarding domain is
# used (only reliably delivers to your own Resend account email).
# CONTACT_FROM=GC Underground <noreply@gulfcoastunderground.org>
